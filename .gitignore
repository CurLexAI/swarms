# Python cache artifacts
__pycache__/
*.py[cod]
*.pyo
.venv/
.venv-modal/

# Local environment and secret material
.env
.env.*
*.env
*.env.*
!.env.example
!**/.env.example

# Node dependency artifacts
node_modules/

# tsc-emitted artifacts not paired with hand-maintained companions
# (AuditService.js, unifiedAgentAdapter.js, sovereignCyberRadar.js ARE tracked)
src/services/ControlPlaneSecurityService.js

# Transient fixtures emitted by node --test for the unified agent adapter
src/services/unifiedAgentAdapter.*.mjs

# TLS certificates (never commit private keys or self-signed certs)
certs/
*.key
*.crt
*.csr
*.srl

# .NET build output
windows-agent/bin/
windows-agent/obj/
windows-agent/publish/

# Go build output
mihwar-core/mihwar-core

# Qarar / Swarms security ignores
.env
.env.*
!.env.example
# Secrets and credentials
*.pem
*.p12
*.pfx
*.jks
*.keystore
service_account.json
google-credentials.json
firebase-adminsdk*.json
# Modal / cloud tokens
modal-token*
.modal.toml
.render/*
render.yaml.local
# Apple / MDM / eSIM sensitive profiles
*.mobileconfig
*.provisionprofile
*.cer
# WireGuard / VPN
wg0.conf
*.conf.key
# Local databases and audit artifacts
*.sqlite
*.sqlite3
*.db
audit.log
audit-*.jsonl
# Notebook checkpoints and outputs
.ipynb_checkpoints/
*.nbconvert.ipynb
# Build and cache
dist/
build/
coverage/
.cache/
.pytest_cache/

# Vercel local project metadata (contains project/org identifiers)
.vercel/
# Secret scanner raw reports (may include raw match payloads even when redacted elsewhere)
gitleaks-report.json
trufflehog-report.json

