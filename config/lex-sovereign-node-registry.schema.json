{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lex Sovereign Node Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","node_id","display_name","role","network","attestation","heartbeat","status"],
  "properties": {
    "schema_version": {"const": 1},
    "node_id": {"type":"string","pattern":"^[a-z0-9][a-z0-9-]{2,62}$"},
    "display_name": {"type":"string","minLength":1,"maxLength":120},
    "role": {"const":"lex-sovereign-node"},
    "network": {"type":"object","additionalProperties":false,"required":["tailscale_tag","control_plane_dns_name"],"properties":{"tailscale_tag":{"const":"tag:lex-sovereign-node"},"control_plane_dns_name":{"type":"string","minLength":1}}},
    "attestation": {"type":"object","additionalProperties":false,"required":["algorithm","key_env"],"properties":{"algorithm":{"const":"HMAC-SHA256"},"key_env":{"type":"string","pattern":"^[A-Z][A-Z0-9_]{2,127}$"}}},
    "heartbeat": {"type":"object","additionalProperties":false,"required":["algorithm","key_env","ttl_seconds"],"properties":{"algorithm":{"const":"HMAC-SHA256"},"key_env":{"type":"string","pattern":"^[A-Z][A-Z0-9_]{2,127}$"},"ttl_seconds":{"type":"integer","minimum":30,"maximum":900}}},
    "status": {"enum":["pending-enrollment","active","revoked","retired"]}
  }
}
