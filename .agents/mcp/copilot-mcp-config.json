{
  "mcpServers": {
    "curlexai-agents": {
      "type": "local",
      "command": "python",
      "args": ["-u", ".agents/mcp/server.py"],
      "tools": ["mihwar_generate", "bayyinah_review"],
      "env": {
        "MIHWAR_ENDPOINT": "$MIHWAR_ENDPOINT",
        "BAYYINAH_ENDPOINT": "$BAYYINAH_ENDPOINT",
        "AGENT_API_TOKEN": "$AGENT_API_TOKEN"
      }
    }
  }
}
