{
  "mcpServers": {
    "curlexai-agents": {
      "type": "stdio",
      "command": "python3",
      "args": [
        ".agents/mcp/server.py"
      ],
      "tools": [
        "mihwar_generate",
        "bayyinah_review",
        "free_birds_review",
        "free_birds_design"
      ],
      "env": {
        "MIHWAR_ENDPOINT": "${COPILOT_MCP_MIHWAR_ENDPOINT}",
        "BAYYINAH_ENDPOINT": "${COPILOT_MCP_BAYYINAH_ENDPOINT}",
        "MIHWAR_API_TOKEN": "${COPILOT_MCP_MIHWAR_API_TOKEN}",
        "BAYYINAH_API_TOKEN": "${COPILOT_MCP_BAYYINAH_API_TOKEN}",
        "AEGIS_MCP_ROLE": "operator",
        "AEGIS_TENANT_ID": "curlexai"
      }
    }
  }
}
