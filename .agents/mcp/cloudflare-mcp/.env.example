# GitHub OAuth App credentials (create at github.com/settings/developers)
GITHUB_CLIENT_ID=__SET_IN_SECRET_STORE__
GITHUB_CLIENT_SECRET=__SET_IN_SECRET_STORE__

# Random hex string for cookie signing (generate: openssl rand -hex 32)
COOKIE_ENCRYPTION_KEY=__SET_IN_SECRET_STORE__

# Modal agent endpoints (backend-only — server-side secret store only; never commit real *.modal.run URLs)
MIHWAR_ENDPOINT=__SET_IN_SECRET_STORE__
BAYYINAH_ENDPOINT=__SET_IN_SECRET_STORE__
MIHWAR_API_TOKEN=__SET_IN_SECRET_STORE__
BAYYINAH_API_TOKEN=__SET_IN_SECRET_STORE__
