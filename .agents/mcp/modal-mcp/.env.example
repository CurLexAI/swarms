# Public MCP server base URL (HTTPS)
MCP_BASE_URL=https://modal-mcp.example.com

# Bearer token expected from ChatGPT MCP connector
MCP_BEARER_TOKEN=replace-me

# Modal API token with read-only scope by default
MODAL_API_TOKEN=replace-me

# Modal API base URL
MODAL_API_BASE_URL=https://api.modal.com

# Keep OFF by default. Required for mutating tools.
ENABLE_MUTATING_TOOLS=false

# Optional: allowlist deployment IDs comma-separated
MODAL_DEPLOYMENT_ALLOWLIST=

# Maximum log lines allowed in modal_get_recent_logs
MAX_LOG_LINES=200
