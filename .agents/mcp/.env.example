# Local-development defaults only. Production must override ENVIRONMENT and ALLOW_ORIGINS.
ENVIRONMENT=development
QARAR_MODAL_APP_NAME=qarar-sovereign-vllm-backend
QARAR_MODAL_FUNCTION_NAME=protected_vllm_inference
# Production/staging must use an explicit allowlist — never '*' and never bare localhost.
ALLOW_ORIGINS=http://localhost:3000
# QARAR_API_TOKEN is required in production; configure in the deployment secret store only.
QARAR_API_TOKEN=__SET_IN_SECRET_STORE__
QARAR_MAX_CONTEXT_FILES=8
QARAR_MAX_READ_BYTES=262144
QARAR_MAX_WRITE_BYTES=524288
QARAR_MAX_TOTAL_CONTEXT_BYTES=524288
QARAR_ENABLE_WORKSPACE_WRITE=false
