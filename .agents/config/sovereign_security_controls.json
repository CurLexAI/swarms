{
  "metadata": {
    "registry_id": "qarar-mihwar-sovereign-security-controls",
    "version": "2026-06-02",
    "status": "architecture_only",
    "evidence_label": "VERIFIED",
    "activation_state": "not_active",
    "owner": "repository-operator",
    "purpose": "Governance registry for the eight proposed sovereign security controls around the Qarar/Mihwar agent operations boundary. This file records intended integration points only; it does not deploy, activate, or call external services.",
    "zero_trust_principle": "Every agent, service, device, and network path is treated as untrusted until authenticated, authorized, inspected, and logged.",
    "compliance_note": "ECC-2:2024 entries are control mappings for design traceability only, not a verified regulatory compliance attestation."
  },
  "constraints": {
    "no_runtime_activation": true,
    "no_external_endpoints": true,
    "no_secret_values": true,
    "fail_closed_required": true,
    "least_privilege_required": true,
    "audit_required": true,
    "decision_executor": "qarar-decision-engine",
    "human_review_required_for_destructive_actions": true
  },
  "controls": [
    {
      "id": "av-clamav",
      "name": "ClamAV antivirus sidecar",
      "category": "AV",
      "layer": "processing-boundary",
      "role": "Scan externally sourced documents before object-store ingestion.",
      "integration_points": [
        "sama-fetcher",
        "minio-ingestion-prewrite",
        "qala-audit-sink"
      ],
      "least_privilege": {
        "runtime_user": "non-root",
        "permissions": [
          "read_new_files_only",
          "no_object_store_write",
          "no_policy_mutation"
        ]
      },
      "audit_events": [
        "malware_scan_requested",
        "malware_scan_completed",
        "malware_scan_blocked"
      ],
      "ecc_mappings": [
        {
          "control": "A.7.6.1",
          "rationale": "Malware protection before processing externally sourced files.",
          "mapping_status": "UNVERIFIED_MAPPING"
        },
        {
          "control": "A.12.2.1",
          "rationale": "Processing controls reject unsafe files before ingestion.",
          "mapping_status": "UNVERIFIED_MAPPING"
        }
      ],
      "activation": {
        "state": "not_active",
        "deployment_surface": "none"
      }
    },
    {
      "id": "edr-wazuh-agent",
      "name": "Wazuh endpoint detection agent",
      "category": "EDR",
      "layer": "workload-runtime",
      "role": "Monitor workload behavior and suspicious process, file, and network activity.",
      "integration_points": [
        "agent-containers",
        "workload-hosts",
        "siem-wazuh-elastic"
      ],
      "least_privilege": {
        "runtime_user": "restricted-monitor",
        "permissions": [
          "observe_process_events",
          "observe_file_events",
          "observe_network_metadata",
          "no_system_mutation"
        ]
      },
      "audit_events": [
        "suspicious_process_detected",
        "protected_model_file_changed",
        "unauthorized_network_flow_detected"
      ],
      "ecc_mappings": [
        {
          "control": "A.8.1.1",
          "rationale": "Runtime inventory signals identify unexpected processes and assets.",
          "mapping_status": "UNVERIFIED_MAPPING"
        },
        {
          "control": "A.10.2.2",
          "rationale": "Network access monitoring identifies unauthorized connections.",
          "mapping_status": "UNVERIFIED_MAPPING"
        }
      ],
      "activation": {
        "state": "not_active",
        "deployment_surface": "none"
      }
    },
    {
      "id": "siem-wazuh-elastic",
      "name": "Wazuh server and Elastic SIEM",
      "category": "SIEM",
      "layer": "evidence-core",
      "role": "Aggregate security events and preserve audit evidence for review.",
      "integration_points": [
        "qarar-security-gate",
        "qala-audit-sink",
        "av-clamav",
        "edr-wazuh-agent",
        "idsips-suricata",
        "dlp-custom-scanner",
        "waf-modsecurity-nginx",
        "nac-tailscale",
        "mtls-vault-pki"
      ],
      "least_privilege": {
        "runtime_user": "siem-service",
        "permissions": [
          "append_security_events",
          "read_own_indices",
          "no_direct_response_actions"
        ]
      },
      "audit_events": [
        "security_event_ingested",
        "audit_query_executed",
        "incident_correlation_created"
      ],
      "ecc_mappings": [
        {
          "control": "A.12.4.1",
          "rationale": "Security events are centrally logged for investigation.",
          "mapping_status": "UNVERIFIED_MAPPING"
        },
        {
          "control": "A.12.4.3",
          "rationale": "Audit logs are intended to be append-only and protected.",
          "mapping_status": "UNVERIFIED_MAPPING"
        }
      ],
      "activation": {
        "state": "not_active",
        "deployment_surface": "none"
      }
    },
    {
      "id": "idsips-suricata",
      "name": "Suricata IDS/IPS",
      "category": "IDS_IPS",
      "layer": "internal-network",
      "role": "Inspect internal container traffic for known attack patterns.",
      "integration_points": [
        "lexprim-net-monitoring-boundary",
