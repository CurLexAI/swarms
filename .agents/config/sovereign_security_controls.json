      "ecc_mappings": [
        {
          "control": "A.9.1.2",
          "rationale": "Network access control is supported by internal traffic inspection.",
          "mapping_status": "UNVERIFIED_MAPPING"
        },
        {
          "control": "A.12.2.1",
          "rationale": "Exploit traffic is rejected before reaching processing services.",
          "mapping_status": "UNVERIFIED_MAPPING"
        }
      ],
      "activation": {
        "state": "not_active",
        "deployment_surface": "none"
      }
    },
    {
      "id": "dlp-custom-scanner",
      "name": "Custom DLP scanner",
      "category": "DLP",
      "layer": "data-egress",
      "role": "Detect secrets and KSA PII before user output or model egress.",
      "integration_points": [
        "qarar-security-gate-output",
        "qala-input-gate",
        "qala-egress-residency-gate",
