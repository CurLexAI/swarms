          "control": "A.9.4.2",
          "rationale": "Application access control is enforced at the API edge.",
          "mapping_status": "UNVERIFIED_MAPPING"
        },
        {
          "control": "A.12.6.1",
          "rationale": "Known technical attack patterns are blocked at ingress.",
          "mapping_status": "UNVERIFIED_MAPPING"
        }
      ],
      "activation": {
        "state": "not_active",
        "deployment_surface": "none"
      }
    },
    {
