      "ecc_mappings": [
        {
          "control": "A.11.2.6",
          "rationale": "Sensitive data transfer is blocked unless authorized.",
          "mapping_status": "UNVERIFIED_MAPPING"
        },
        {
          "control": "A.8.2.3",
          "rationale": "Sensitive data handling is checked before release.",
          "mapping_status": "UNVERIFIED_MAPPING"
