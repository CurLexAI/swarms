      "id": "edr-suspicious-process-isolation",
      "trigger_control": "edr-wazuh-agent",
      "trigger_event": "suspicious_process_detected",
      "qarar_response": [
        "request_container_isolation",
        "request_nac_blocklist_draft",
        "notify_security_operator"
      ],
      "guardrails": [
        "qarar_decision_required",
        "human_review_required_for_business_impact",
        "audit_before_action"
      ],
      "ecc_mappings": [
        {
          "control": "A.12.6.1",
          "mapping_status": "UNVERIFIED_MAPPING"
        }
      ]
    },
