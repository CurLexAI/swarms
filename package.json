{
  "name": "curlexai-swarms",
  "version": "1.0.0",
  "description": "CurLexAI agent operations layer — swarm tooling, review automation, and agent orchestration",
  "type": "module",
  "scripts": {
    "test": "node --test tests/unifiedAgentAdapter.test.js tests/unifiedAgentAdapter.executeAgent.non2xx.integration.test.js tests/unifiedAgentAdapter.nodeDispatch.integration.test.js",
    "test:unit": "node --test tests/unifiedAgentAdapter.test.js",
    "test:security": "node --test tests/sovereignCyberRadar.test.js",
    "build": "tsc -p tsconfig.json",
    "check:service-divergence": "node scripts/check-service-divergence.mjs",
    "check:boundary": "bash scripts/commander/adr-0001-boundary-gate.sh .",
    "check:audit-integrity": "bash scripts/commander/qala-audit-integrity-gate.sh .",
    "check:audit-chain": "bash scripts/commander/qala-audit-integrity-gate.sh .",
    "check:cdn-sri": "node scripts/check-cdn-sri.mjs",
    "check:swarms-presence": "python3 scripts/commander/swarm-presence-monitor.py --repo-root . --no-network",
    "check:swarms-extraction": "python3 scripts/commander/swarms-extraction-gate.py --repo-root .",
    "check:supabase-boundary": "node scripts/check-supabase-public-boundary.mjs",
    "check:runtime-policy": "tsx scripts/check-runtime-policy.ts",
    "test:runtime-policy": "node --import tsx --test tests/runtime-policy.test.ts",
    "check:swarms-presence:strict": "python3 scripts/commander/swarm-presence-monitor.py --repo-root . --strict",
    "check": "npm run check:service-divergence && npm run test:unit && npm run check:boundary && npm run check:cdn-sri && npm run check:audit-integrity && npm run check:swarms-presence && npm run check:swarms-extraction",
    "security:radar:url": "tsx src/security/sovereignCyberRadar.ts scan-url",
    "security:radar:text": "tsx src/security/sovereignCyberRadar.ts scan-text",
    "security:radar:command": "tsx src/security/sovereignCyberRadar.ts scan-command",
    "security:radar:simulate": "tsx src/security/sovereignCyberRadar.ts simulate",
    "integrity:frontend": "node scripts/generate-frontend-integrity.mjs",
    "test:cdn-sri": "node --test tests/cdn-sri-validation.test.js",
    "doctor:cli": "node scripts/dev-cli-doctor.mjs",
    "deploy:evidence:validate": "node scripts/validate-launch-evidence.mjs",
    "test:python": "python3 -m pytest -q tests/",
    "test:node:js": "node --import tsx --test tests/*.test.js",
    "test:node:ts": "node --import tsx --test tests/*.test.ts",
    "test:node": "npm run test:node:js && npm run test:node:ts",
    "start": "node scripts/render/serve-public.mjs",
    "test:render-public": "node --test tests/renderPublicServer.test.js",
    "ollama:activate-local": "bash scripts/ollama/activate-local-models.sh",
    "ollama:verify-local": "OLLAMA_PULL=0 bash scripts/ollama/activate-local-models.sh"
  },
  "dependencies": {
    "js-yaml": "^5.2.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
