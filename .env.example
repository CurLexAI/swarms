NODE_ENV=development
MIHWAR_ENV=development
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
REDIS_PASSWORD=
REDIS_URL=
MIHWAR_HMAC_SECRET=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
QARAR_RAG_HMAC_SECRET=
QDRANT_API_KEY=
MCP_BEARER_TOKEN=
BAYYINAH_AGENT_TOKEN=
MIHWAR_AGENT_TOKEN=
SMOKE_TEST_TOKEN=
# CurLexAI/swarms operator environment example
# Do not place real values in this file. Configure live values in GitHub/Render/Modal secret stores.

NODE_ENV=production

# Public origins only. Keep comma-separated, no spaces.
CORS_ORIGINS=https://lexprim.com,https://www.lexprim.com

# GitHub API token for operator-only live checks. Use least privilege and rotate after exposure.
GITHUB_TOKEN=__SET_IN_SECRET_STORE__
GITHUB_WEBHOOK_SECRET=__SET_IN_SECRET_STORE__

# MCP / Render operator checks.
MCP_SERVER_URL=https://sr-bsm.onrender.com/healthz
MCP_BEARER_TOKEN=__SET_IN_SECRET_STORE__

# Qarar/Bayyinah/Mihwar private runtime. Never expose these to browser code.
MIHWAR_ENDPOINT=__SET_IN_SECRET_STORE__
BAYYINAH_ENDPOINT=__SET_IN_SECRET_STORE__
AGENT_API_TOKEN=__SET_IN_SECRET_STORE__

# Optional identity-provider check.
ENTRA_TENANT_ID=__SET_IN_SECRET_STORE__

# Optional operations bot. Never commit the real token.
RAPTOR_POLLING_MODE=false
RAPTOR_TELEGRAM_BOT_TOKEN=__SET_IN_SECRET_STORE__
RAPTOR_ADMIN_CHAT_ID=__SET_IN_SECRET_STORE__

# Optional Supabase backend. Placeholder values only; configure live values in the deployment secret store.
# Browser/client code may use only SUPABASE_URL and SUPABASE_ANON_KEY.
SUPABASE_URL=__OPTIONAL_SUPABASE_URL__
SUPABASE_ANON_KEY=__OPTIONAL_PUBLIC_ANON_KEY__
# Server-side secret-store only. Never expose to browser/client bundles, public assets, logs, or PR comments.
SUPABASE_SERVICE_ROLE_KEY=__SET_IN_SERVER_SECRET_STORE_ONLY__
