# CurLexAI/swarms operator environment example
# Do not place real values in this file. Configure live values in GitHub/Render/Modal secret stores.

NODE_ENV=production
MIHWAR_ENV=production

# Database / cache placeholders. Keep empty locally unless explicitly required.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
REDIS_PASSWORD=
REDIS_URL=

# HMAC / internal auth placeholders. Never commit real values.
MIHWAR_HMAC_SECRET=__SET_IN_SECRET_STORE__
QARAR_RAG_HMAC_SECRET=__SET_IN_SECRET_STORE__
MCP_BEARER_TOKEN=__SET_IN_SECRET_STORE__
SMOKE_TEST_TOKEN=__SET_IN_SECRET_STORE__

# Public origins only. Keep comma-separated, no spaces.
CORS_ORIGINS=https://lexprim.com,https://www.lexprim.com

# GitHub API token for operator-only live checks. Use least privilege and rotate after exposure.
GITHUB_TOKEN=__SET_IN_SECRET_STORE__
GITHUB_WEBHOOK_SECRET=__SET_IN_SECRET_STORE__

# MCP / Render operator checks.
MCP_SERVER_URL=https://sr-bsm.onrender.com/healthz

# Qarar/Bayyinah/Mihwar private runtime. Never expose these to browser code.
MIHWAR_ENDPOINT=__SET_IN_SECRET_STORE__
MIHWAR_API_TOKEN=__SET_IN_SECRET_STORE__
BAYYINAH_ENDPOINT=__SET_IN_SECRET_STORE__
BAYYINAH_API_TOKEN=__SET_IN_SECRET_STORE__

# Modal deployment credentials. Configure only in approved Actions/Modal secret stores.
MODAL_TOKEN_ID=__SET_IN_SECRET_STORE__
MODAL_TOKEN_SECRET=__SET_IN_SECRET_STORE__
MIHWAR_MODEL_REVISION=__FULL_40_CHAR_HF_COMMIT_SHA__
BAYYINAH_MODEL_REVISION=__FULL_40_CHAR_HF_COMMIT_SHA__
MIHWAR_REMOTE_CODE_ACK=
BAYYINAH_REMOTE_CODE_ACK=

# Qdrant sovereign RAG path. QDRANT_API_KEY is mandatory in production
# and in any reachable runtime. The unauthenticated flag is local/dev-only
# break-glass and must also use a private/local QDRANT_INTERNAL_URL.
QDRANT_INTERNAL_URL=__SET_IN_SECRET_STORE__
QDRANT_API_KEY=__SET_IN_SECRET_STORE__
ALLOW_UNAUTHENTICATED_QDRANT=false

# Optional identity-provider check.
ENTRA_TENANT_ID=__SET_IN_SECRET_STORE__

# Optional operations bot. Never commit the real token.
RAPTOR_POLLING_MODE=false
RAPTOR_TELEGRAM_BOT_TOKEN=__SET_IN_SECRET_STORE__
RAPTOR_ADMIN_CHAT_ID=__SET_IN_SECRET_STORE__

# Quicknode Web3 RPC boundary (disabled by default).
# Keep QUICKNODE_ENABLED=false unless explicitly enabled by an operator.
# QUICKNODE_RPC_URL is a secret-store value only; never commit a real RPC URL because
# provider tokens may be embedded in the host, path, or query string.
QUICKNODE_ENABLED=false
QUICKNODE_RPC_URL=__SET_IN_SECRET_STORE__
QUICKNODE_NETWORK=__OPTIONAL_PUBLIC_NETWORK_LABEL__
QUICKNODE_CHAIN_ID=__OPTIONAL_CHAIN_ID__

# Optional Supabase backend. Placeholder values only; configure live values in the deployment secret store.
# Browser/client code may use only SUPABASE_URL and SUPABASE_ANON_KEY.
SUPABASE_URL=__OPTIONAL_SUPABASE_URL__
SUPABASE_ANON_KEY=__OPTIONAL_PUBLIC_ANON_KEY__
# Server-side secret-store only. Never expose to browser/client bundles, public assets, logs, or PR comments.
SUPABASE_SERVICE_ROLE_KEY=__SET_IN_SERVER_SECRET_STORE_ONLY__

# Linear integration placeholders.
LINEAR_API_KEY=__SET_IN_SECRET_STORE__
LINEAR_WEBHOOK_SECRET=__SET_IN_SECRET_STORE__
LINEAR_TEAM_KEY=__CONFIGURE_APPROVED_TEAM_KEY__
LINEAR_SYNC_DRY_RUN=true

# Hugging Face artifact boundary (disabled by default).
# Configure live values only in an approved secret store after human review.
HF_INTEGRATION_MODE=disabled
HF_HOME=__LOCAL_CACHE_PATH_ONLY__
HF_MODEL_REPO=__APPROVED_MODEL_REPO_ID__
HF_TOKEN=__SET_IN_SECRET_STORE__
